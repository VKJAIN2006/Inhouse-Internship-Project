   "source": [
    "# Convert a series of date strings to a time series\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "dates = pd.Series([\n",
    "    \"2025-01-10\",\n",
    "    \"2025-02-15\",\n",
    "    \"2025-03-20\",\n",
    "    \"2025-04-25\"\n",
    "])\n",
    "\n",
    "# Convert string series into datetime series\n",
    "\n",
    "timeseries = pd.to_datetime(dates)\n",
    "\n",
    "print(timeseries)"
   ]
  }
 ],
